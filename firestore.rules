rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }
    function isSignedIn() { return request.auth != null; }

    match /restaurantProfile/{profileId} { allow read, write: if true; }
    match /categories/{categoryId} { allow read: if true; allow write: if isSignedIn(); }
    match /products/{productId} { allow read: if true; allow write: if isSignedIn(); }
    match /complements/{productId} { allow read: if true; allow write: if isSignedIn(); }
    match /coupons/{couponId} { allow read: if true; allow write: if isSignedIn(); }
    match /orders/{orderId} { allow read, write: if true; }
    match /clients/{phone} { allow read, write: if true; }
    match /appSettings/{settingId} { allow read, write: if true; }
  }
}
