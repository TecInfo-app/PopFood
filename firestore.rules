rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regra de segurança global: por padrão bloqueia tudo que não estiver mapeado abaixo
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper para verificar se temos um usuário autenticado no sistema
    function isSignedIn() {
      return request.auth != null;
    }

    // Perfis dos Restaurantes (Permite que o painel gerencie a lista de lojas)
    match /restaurantProfile/{profileId} {
      allow read, write: if true;
    }

    // Categorias de Cardápio
    match /categories/{categoryId} {
      allow read, write: if true;
    }

    // Produtos
    match /products/{productId} {
      allow read, write: if true;
    }

    // Complementos/Adicionais dos itens
    match /complements/{productId} {
      allow read, write: if true;
    }

    // Cupons ativos
    match /coupons/{couponId} {
      allow read, write: if true;
    }

    // Pedidos (Clientes e Restaurantes gravam e leem, estatísticas gerais)
    match /orders/{orderId} {
      allow read, write: if true;
    }

    // Clientes cadastrados para histórico
    match /clients/{phone} {
      allow read, write: if true;
    }

    // Permite salvar a chave API do sistema
    match /appSettings/{settingId} {
      allow read, write: if true;
    }

    // Campanhas de push / notificações
    match /campaigns/{campaignId} {
      allow read, write: if true;
    }
  }
}
