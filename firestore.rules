rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net (Zero-Trust entry point)
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        'email' in request.auth.token && (
          request.auth.token.email.lower() == "iranildo@popfood.com" || 
          request.auth.token.email.lower() == "ciachopp2016@gmail.com"
        );
    }

    function isStoreOwner(storeId) {
      return isSignedIn() && (
        storeId == request.auth.uid || 
        isAdmin() ||
        (exists(/databases/$(database)/documents/restaurantProfile/$(storeId)) && 
         'email' in request.auth.token &&
         get(/databases/$(database)/documents/restaurantProfile/$(storeId)).data.keys().hasAll(['adminEmail']) && 
         get(/databases/$(database)/documents/restaurantProfile/$(storeId)).data.adminEmail.lower() == request.auth.token.email.lower())
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Categories Rules
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isStoreOwner(incoming().storeId);
      allow update: if isStoreOwner(existing().storeId) && isStoreOwner(incoming().storeId);
      allow delete: if isStoreOwner(existing().storeId);
    }

    // Products Rules
    match /products/{productId} {
      allow read: if true;
      allow create: if isStoreOwner(incoming().storeId);
      allow update: if isStoreOwner(existing().storeId) && isStoreOwner(incoming().storeId);
      allow delete: if isStoreOwner(existing().storeId);
    }

    // Complements Rules
    match /complements/{productId} {
      allow read: if true;
      allow create: if isStoreOwner(incoming().storeId);
      allow update: if isStoreOwner(existing().storeId) && isStoreOwner(incoming().storeId);
      allow delete: if isStoreOwner(existing().storeId);
    }

    // Coupons Rules
    match /coupons/{couponId} {
      allow read: if true;
      allow create: if isStoreOwner(incoming().storeId);
      allow update: if isStoreOwner(existing().storeId) && isStoreOwner(incoming().storeId);
      allow delete: if isStoreOwner(existing().storeId);
    }

    // Restaurant Profiles Rules
    match /restaurantProfile/{profileId} {
      allow read: if (profileId == 'GLOBAL_SETTINGS') ? isSignedIn() : true;
      
      function isProfileOwner(profId) {
        return isSignedIn() && (
          profId == request.auth.uid || 
          profId.matches('^' + request.auth.uid + '(_logo|_banner[0-2])?$') ||
          isAdmin() ||
          ('email' in request.auth.token && (
            (resource != null && resource.data.keys().hasAll(['adminEmail']) && 
             resource.data.adminEmail.lower() == request.auth.token.email.lower()) ||
            (request.resource != null && request.resource.data.keys().hasAll(['adminEmail']) && 
             request.resource.data.adminEmail.lower() == request.auth.token.email.lower())
          ))
        );
      }

      allow write: if (profileId == 'GLOBAL_SETTINGS') 
        ? isAdmin() 
        : isProfileOwner(profileId);
    }

    // Orders Rules - Multi-level authorization
    match /orders/{orderId} {
      allow read: if true;
      allow create: if true;
      allow update: if (isStoreOwner(existing().storeId))
        || (!isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly([
            'rating', 'deliveryPin', 'motoboyLatitude', 'motoboyLongitude', 
            'status', 'deliveryProgress', 'deliveryMilestone', 
            'paymentApproved', 'isPaid', 'paymentStatus'
          ]));
      allow delete: if isStoreOwner(existing().storeId);
    }

    // Clients Rules - Restrict public lists
    match /clients/{phone} {
      allow read: if isStoreOwner(resource.data.storeId);
      allow create, update: if true;
      allow delete: if isStoreOwner(existing().storeId);
    }
  }
}
