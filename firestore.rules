rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isStoreOwner(storeId) {
      return isSignedIn() && request.auth.uid == storeId;
    }

    function isAdmin() {
      // Legacy global admin bypass if needed
      return isSignedIn() && request.auth.token.email == "ciachopp2016@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Categories Validation
    function isValidCategory(data) {
      return data.keys().hasAll(['id', 'name', 'order', 'createdAt', 'storeId'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.order is int
        && data.storeId is string
        && (data.createdAt is string || data.createdAt is timestamp);
    }

    match /categories/{categoryId} {
      allow read, write: if true;
    }

    match /products/{productId} {
      allow read, write: if true;
    }

    match /complements/{productId} {
      allow read, write: if true;
    }

    match /restaurantProfile/main {
      allow read, write: if true;
    }
    
    match /restaurantProfile/{profileId} {
      allow read, write: if true;
    }

    match /coupons/{couponId} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
      allow read, write: if true;
    }

    match /clients/{phone} {
      allow read, write: if true;
    }

    match /appSettings/{settingId} {
      allow read, write: if true;
    }
  }
}
